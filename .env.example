# Required: tu dirección Tempo (donde llegan los $1 USDC.e por cada compra).
# Genérala con: npx mppx account create
MPP_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# Required: secreto HMAC para firmar challenges 402 (estabilidad entre instancias).
# Genéralo con: openssl rand -hex 32
MPP_SECRET_KEY=replace-me-with-openssl-rand-hex-32

# Optional: "false" para mainnet Tempo. Default = testnet.
# MPP_TESTNET=true
